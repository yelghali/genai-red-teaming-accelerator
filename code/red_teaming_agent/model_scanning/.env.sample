# Azure AI Foundry project endpoint (required)
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project

# Models to scan (comma-separated deployment names, required)
# Chat models → scanned via cloud evals API (azure_ai_model target)
# Document AI models → scanned via local RedTeam SDK with custom callback
RED_TEAM_MODELS=gpt-5-1,gpt-5-3,gpt-5-4,mistral-large-3,mistral-document-ai

# Attack difficulty: easy | moderate | difficult | all (default: easy)
RED_TEAM_DIFFICULTY=easy

# Number of simulation turns per attack (default: 1)
RED_TEAM_NUM_TURNS=1

# Polling timeout in minutes (default: 30)
RED_TEAM_TIMEOUT_MINUTES=30
